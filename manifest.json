{
  "manifest_version": 3,
  "name": "YouTube Viewport Fullscreen",
  "version": "0.1.0",
  "description": "Adds a custom viewport fullscreen button to the YouTube player.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
    "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon32.png",
      "32": "icons/icon48.png"
    },
    "default_title": "YouTube Windowed Fullscreen",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
